          "stringUnit" : {
            "state" : "translated",
            "value" : "MacCam records audio in clips when audio recording is enabled."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "MacCam записывает звук в клипах, если включена запись звука."
