    "Always records while monitoring (no detector).": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nimmt bei der Überwachung immer auf (keine Erkennung)."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Graba siempre durante la supervisión (sin detector)."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistre en continu pendant la surveillance (sans détecteur)."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra sempre durante il monitoraggio (nessun rilevatore)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "監視中は常に録画します（検出なし）。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Grava sempre durante o monitoramento (sem detector)."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пишет всегда во время наблюдения (без детектора)."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "监控期间始终录制（无检测器）。"
          }
        }
      }
    },
