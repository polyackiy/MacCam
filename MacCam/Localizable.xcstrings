    "Startup" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Запуск" } } } },
    "Always records while monitoring (no detector)." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Пишет всегда во время наблюдения (без детектора)." } } } },
    "Records when motion is detected." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Пишет при обнаружении движения." } } } },
    "Records when human speech is detected." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Пишет при обнаружении человеческой речи." } } } },
    "Records on motion or speech." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Пишет при движении или речи." } } } },
    "Voice trigger needs \"Record audio\" enabled on the Camera tab." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Для триггера по голосу включите «Запись звука» на вкладке «Камера»." } } } },
    "Audio-only recording is on — the camera is disabled." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Включена запись только звука — камера отключена." } } } },
    "Keeps recording this long after the trigger stops; longer events split into clips of the max length." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Продолжает запись столько после остановки триггера; длинные события делятся на клипы максимальной длины." } } } },
    "A manual Start always takes priority over guard mode and schedules." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ручной запуск всегда важнее режима охраны и расписаний." } } } },
    "Loop deletes the oldest clips to stay under the limit; Stop & notify halts recording instead." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "«Цикл» удаляет старые клипы ради лимита; «Остановить и уведомить» вместо этого прекращает запись." } } } },
    "Version %@ (%@)" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Версия %@ (%@)" } } } }
  }
