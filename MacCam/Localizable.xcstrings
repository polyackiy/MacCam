    "Tap or drag cells to ignore (red). Motion there is not detected.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tippe oder ziehe über Zellen, um sie zu ignorieren (rot). Bewegung dort wird nicht erkannt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Toca o arrastra las celdas para ignorarlas (rojo). El movimiento ahí no se detecta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Touchez ou faites glisser les cellules à ignorer (rouge). Les mouvements y sont ignorés."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocca o trascina le celle da ignorare (rosso). Il movimento in quelle aree non viene rilevato."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "セルをタップまたはドラッグして無視（赤）に設定します。その範囲のモーションは検出されません。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Toque ou arraste as células para ignorá-las (vermelho). O movimento nelas não é detectado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Нажимайте или ведите по ячейкам, чтобы игнорировать (красные). Движение там не учитывается."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点按或拖动单元格以忽略（红色）。该处的移动不会被检测。"
          }
        }
      }
    },
