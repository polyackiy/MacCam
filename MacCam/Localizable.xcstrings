            "state": "translated",
            "value": "Mantener libre: %lld GB (0 = desactivado)"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Garder libre : %lld Go (0 = désactivé)"
          }
        },
        "it": {
