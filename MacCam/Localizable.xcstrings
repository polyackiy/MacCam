    "A manual Start always takes priority over guard mode and schedules.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein manueller Start hat immer Vorrang vor dem Wächtermodus und Zeitplänen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Iniciar manualmente siempre tiene prioridad sobre el modo de vigilancia y las programaciones."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un démarrage manuel a toujours priorité sur le mode garde et les horaires."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un avvio manuale ha sempre la priorità sulla modalità sorveglianza e sulle pianificazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "手動の開始は、ガードモードやスケジュールよりも常に優先されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um início manual sempre tem prioridade sobre o modo de guarda e as agendas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ручной запуск всегда важнее режима охраны и расписаний."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "手动开始的优先级始终高于护卫模式和日程。"
          }
        }
      }
    },
