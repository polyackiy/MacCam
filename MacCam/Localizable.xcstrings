    "MacCam needs camera access to monitor for motion. Enable it in System Settings → Privacy & Security → Camera.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam benötigt Kamerazugriff, um auf Bewegung zu überwachen. Aktiviere ihn unter „Systemeinstellungen“ → „Datenschutz & Sicherheit“ → „Kamera“."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam necesita acceso a la cámara para detectar movimiento. Actívalo en Ajustes del Sistema → Privacidad y seguridad → Cámara."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam a besoin d'accéder à la caméra pour détecter les mouvements. Activez-le dans Réglages Système → Confidentialité et sécurité → Caméra."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam ha bisogno dell'accesso alla videocamera per rilevare il movimento. Attivalo in Impostazioni di Sistema → Privacy e sicurezza → Videocamera."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam がモーションを監視するにはカメラへのアクセスが必要です。「システム設定」→「プライバシーとセキュリティ」→「カメラ」で有効にしてください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O MacCam precisa de acesso à câmera para monitorar movimento. Ative em Ajustes do Sistema → Privacidade e Segurança → Câmera."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam нужен доступ к камере для наблюдения за движением. Включите его в Системных настройках → Конфиденциальность и безопасность → Камера."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam 需要摄像头访问权限以监控移动。请在“系统设置”→“隐私与安全性”→“摄像头”中启用。"
          }
        }
      }
    },
    "MacCam needs microphone access to record audio. Enable it in System Settings → Privacy & Security → Microphone.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam benötigt Mikrofonzugriff, um Audio aufzunehmen. Aktiviere ihn unter „Systemeinstellungen“ → „Datenschutz & Sicherheit“ → „Mikrofon“."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam necesita acceso al micrófono para grabar audio. Actívalo en Ajustes del Sistema → Privacidad y seguridad → Micrófono."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam a besoin d'accéder au microphone pour enregistrer l'audio. Activez-le dans Réglages Système → Confidentialité et sécurité → Microphone."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam ha bisogno dell'accesso al microfono per registrare l'audio. Attivalo in Impostazioni di Sistema → Privacy e sicurezza → Microfono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam がオーディオを録音するにはマイクへのアクセスが必要です。「システム設定」→「プライバシーとセキュリティ」→「マイク」で有効にしてください。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O MacCam precisa de acesso ao microfone para gravar áudio. Ative em Ajustes do Sistema → Privacidade e Segurança → Microfone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam нужен доступ к микрофону для записи звука. Включите его в Системных настройках → Конфиденциальность и безопасность → Микрофон."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "MacCam 需要麦克风访问权限以录制音频。请在“系统设置”→“隐私与安全性”→“麦克风”中启用。"
          }
        }
      }
    },
