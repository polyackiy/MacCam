    "Microphone" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Микрофон" } } } },
    "Microphone access denied" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Доступ к микрофону запрещён" } } } },
    "MacCam needs microphone access to record audio. Enable it in System Settings → Privacy & Security → Microphone." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "MacCam нужен доступ к микрофону для записи звука. Включите его в Системных настройках → Конфиденциальность и безопасность → Микрофон." } } } },
    "Clear" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Очистить" } } } },
