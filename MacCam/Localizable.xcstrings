    "Audio-only recording is on — the camera is disabled.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nur-Audio-Aufnahme ist aktiviert – die Kamera ist deaktiviert."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La grabación de solo audio está activada; la cámara está desactivada."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'enregistrement audio seul est activé — la caméra est désactivée."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La registrazione solo audio è attiva: la videocamera è disattivata."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オーディオのみの録音が有効です。カメラは無効になっています。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A gravação apenas de áudio está ativada — a câmera está desativada."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включена запись только звука — камера отключена."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已开启仅音频录制——摄像头已停用。"
          }
        }
      }
    },
