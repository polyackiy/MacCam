          }
        }
      }
    },
    "Keeps recording this long after the trigger stops; longer events split into clips of the max length.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Nimmt nach dem Ende des Auslösers noch so lange auf; längere Ereignisse werden in Clips mit maximaler Länge aufgeteilt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sigue grabando este tiempo después de que se detenga el activador; los eventos más largos se dividen en clips de la duración máxima."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Continue d'enregistrer aussi longtemps après l'arrêt du déclencheur ; les événements plus longs sont découpés en clips de la durée maximale."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Continua a registrare per questo tempo dopo che il trigger si interrompe; gli eventi più lunghi vengono suddivisi in clip della durata massima."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "トリガー停止後もこの時間だけ録画を続けます。長いイベントは最大長のクリップに分割されます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Continua gravando por este tempo após o gatilho parar; eventos mais longos são divididos em clipes com a duração máxima."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Продолжает запись столько после остановки триггера; длинные события делятся на клипы максимальной длины."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "触发停止后继续录制这段时长；更长的事件会拆分为最大长度的片段。"
          }
        }
      }
    },
