    "Loop deletes the oldest clips to stay under the limit; Stop & notify halts recording instead.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "„Schleife“ löscht die ältesten Clips, um unter dem Limit zu bleiben; „Stoppen & melden“ beendet stattdessen die Aufnahme."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El bucle elimina los clips más antiguos para no superar el límite; «Detener y notificar» detiene la grabación en su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Boucle supprime les clips les plus anciens pour rester sous la limite ; Arrêter et notifier interrompt plutôt l'enregistrement."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Loop elimina i clip più vecchi per restare sotto il limite; Interrompi e avvisa ferma invece la registrazione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ループは上限を超えないよう最も古いクリップを削除します。停止して通知は代わりに録画を停止します。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O modo Repetição apaga os clipes mais antigos para ficar abaixo do limite; Parar e notificar interrompe a gravação."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "«Цикл» удаляет старые клипы ради лимита; «Остановить и уведомить» вместо этого прекращает запись."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "“循环”会删除最旧的片段以保持在限制内；“停止并通知”则会停止录制。"
          }
        }
      }
    },
    "MacCam Settings": {
      "localizations": {
