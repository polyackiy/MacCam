    "Invert" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Инвертировать" } } } },
    "Stopped: disk limit reached" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Остановлено: достигнут лимит диска" } } } },
    "Tap or drag cells to ignore (red). Motion there is not detected." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Нажимайте или ведите по ячейкам, чтобы игнорировать (красные). Движение там не учитывается." } } } },
