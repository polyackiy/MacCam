    "Guard mode: monitor while screen is locked" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Режим охраны: наблюдение при заблокированном экране" } } } },
    "Idle" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ожидание" } } } },
    "In discreet mode the icon looks the same whether idle, monitoring, or recording — only this menu reveals the real status." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "В незаметном режиме значок выглядит одинаково при ожидании, наблюдении и записи — реальный статус виден только в этом меню." } } } },
    "Last clip: %@" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Последний клип: %@" } } } },
    "Launch at login" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Запуск при входе в систему" } } } },
