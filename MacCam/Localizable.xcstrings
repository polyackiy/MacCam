    "Available with the Continuous or Voice trigger and Record audio on.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Verfügbar mit dem Auslöser „Kontinuierlich“ oder „Stimme“ und aktivierter Audioaufnahme."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponible con el activador Continuo o Voz y «Grabar audio» activado."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponible avec le déclencheur Continu ou Voix et l'enregistrement audio activé."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponibile con il trigger Continuo o Voce e con Registra audio attivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "連続または音声トリガーで、音声を録音が有効な場合に利用できます。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Disponível com o gatilho Contínuo ou Voz e Gravar áudio ativado."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступно при триггере «Непрерывно» или «Голос» и включённой записи звука."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在“持续”或“语音”触发且开启录制音频时可用。"
          }
        }
      }
    },
