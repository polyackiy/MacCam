    "Monitoring schedule" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Расписание наблюдения" } } } },
    "Overnight windows (start after end) span midnight." : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Ночные окна (начало позже конца) переходят через полночь." } } } },
    "Recording schedule" : { "localizations" : { "ru" : { "stringUnit" : { "state" : "translated", "value" : "Расписание записи" } } } },
